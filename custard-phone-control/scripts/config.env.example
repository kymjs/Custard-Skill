# 从 CustardMac「Agent 端口」页复制 Token
# 仓库：https://github.com/kymjs/Custard-Skill
# 勿提交 config.env（已在 .gitignore）
CUSTARD_AGENT_TOKEN=your-token-here
CUSTARD_TOOL_HOST=127.0.0.1
CUSTARD_TOOL_PORT=27184
CUSTARD_SKILL_DIR=$HOME/.cursor/skills/custard-phone-control
CUSTARD_TOOL_SOURCE=agent
# 截图缓存目录（可选，默认 <skill>/cache）
# CUSTARD_SCREEN_CACHE=$HOME/.cursor/skills/custard-phone-control/cache
